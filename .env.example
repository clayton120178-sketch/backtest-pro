# Supabase
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=xxxyyyyxyxyxyxyx
SERVICE_ROLE_KEY=xxxyyyyxyxyxyxyx
SUPABASE_SERVICE_KEY=xxxyyyyxyxyxyxyx

# Worker
WORKER_ID=local-dev-01
POLL_INTERVAL=5
MAX_BACKTEST_TIMEOUT=3600

# MT5 — ajustar conforme a maquina/VPS
# MT5_PATH: caminho completo para o terminal64.exe
# MT5_GUID: nome da pasta em %APPDATA%\MetaQuotes\Terminal\
# MT5_DATA_DIR: caminho completo da pasta de dados do MT5 (recomendado definir explicitamente na VPS)
MT5_PATH=C:\Program Files\MetaTrader 5\terminal64.exe
MT5_GUID=COLE_AQUI_O_GUID_DO_MT5
MT5_DATA_DIR=C:\Users\SEU_USUARIO\AppData\Roaming\MetaQuotes\Terminal\COLE_AQUI_O_GUID_DO_MT5

# Mercado Pago
MP_ACCESS_TOKEN=your_mp_access_token_here
MP_PUBLIC_KEY=APP_USR-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
